  <!-- ================================================================== -->
  <!-- FORM-LEVEL TRIGGERS                                                 -->
  <!-- ================================================================== -->
  <Trigger Name="WHEN-NEW-FORM-INSTANCE" TriggerStyle="PL/SQL" FireInEnterQueryMode="No">
    <TriggerText>
DECLARE
    v_session_id NUMBER;
BEGIN
    -- Validate session
    v_session_id := TO_NUMBER(GET_APPLICATION_PROPERTY(USERNAME));
    IF NOT PKG_SECURITY.is_session_valid(v_session_id) THEN
        MESSAGE('Session expired. Please log in again.');
        RAISE FORM_TRIGGER_FAILURE;
    END IF;

    -- Set window title
    SET_WINDOW_PROPERTY(FORMS_MDI_WINDOW, TITLE,
        'HRMS - Employee Maintenance [' || :GLOBAL.current_user || ']');

    -- Restrict based on permissions
    IF NOT PKG_SECURITY.has_permission(:GLOBAL.current_emp_id, 'EMPLOYEE', 'EDIT') THEN
        SET_BLOCK_PROPERTY('EMPLOYEE', INSERT_ALLOWED, PROPERTY_FALSE);
        SET_BLOCK_PROPERTY('EMPLOYEE', UPDATE_ALLOWED, PROPERTY_FALSE);
        SET_BLOCK_PROPERTY('EMPLOYEE', DELETE_ALLOWED, PROPERTY_FALSE);
    END IF;

    -- Default query to active employees
    SET_BLOCK_PROPERTY('EMPLOYEE', DEFAULT_WHERE,
        'EMPLOYMENT_STATUS = ''ACTIVE'' AND ACTIVE_FLAG = ''Y''');

    -- Initialize LOVs
    POPULATE_GROUP('RG_DEPARTMENTS');
    POPULATE_GROUP('RG_JOB_TITLES');
    POPULATE_GROUP('RG_LOCATIONS');

    GO_BLOCK('EMPLOYEE');
    EXECUTE_QUERY;
END;
    </TriggerText>
  </Trigger>

  <Trigger Name="ON-ERROR" TriggerStyle="PL/SQL" FireInEnterQueryMode="Yes">
    <TriggerText>
DECLARE
    v_errcode NUMBER := ERROR_CODE;
    v_errtype VARCHAR2(3) := ERROR_TYPE;
    v_errmsg  VARCHAR2(200) := ERROR_TEXT;
BEGIN
    IF v_errcode = 40202 THEN
        -- "Field is protected against update"
        NULL; -- Suppress
    ELSIF v_errcode = 40401 THEN
        -- "No changes to save"
        MESSAGE('No changes to save.');
    ELSIF v_errcode = 40501 THEN
        -- "Oracle error: unable to reserve record"
        MESSAGE('Record is locked by another user. Please try again.');
    ELSE
        MESSAGE(v_errtype || '-' || TO_CHAR(v_errcode) || ': ' || v_errmsg);
        RAISE FORM_TRIGGER_FAILURE;
    END IF;
END;
    </TriggerText>
  </Trigger>

  <Trigger Name="KEY-EXIT" TriggerStyle="PL/SQL" FireInEnterQueryMode="Yes">
    <TriggerText>
BEGIN
    IF :SYSTEM.FORM_STATUS = 'CHANGED' THEN
        IF SHOW_ALERT('ALT_CONFIRM_EXIT') = ALERT_BUTTON1 THEN
            COMMIT_FORM;
        ELSIF SHOW_ALERT('ALT_CONFIRM_EXIT') = ALERT_BUTTON2 THEN
            CLEAR_FORM(NO_VALIDATE);
        ELSE
            RAISE FORM_TRIGGER_FAILURE;
        END IF;
    END IF;
    EXIT_FORM;
END;
    </TriggerText>
  </Trigger>

