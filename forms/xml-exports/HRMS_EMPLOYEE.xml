    <!-- Block-level triggers -->
    <Trigger Name="PRE-INSERT" TriggerStyle="PL/SQL">
      <TriggerText>
BEGIN
    :EMPLOYEE.EMP_ID := SEQ_EMPLOYEE.NEXTVAL;
    :EMPLOYEE.EMP_NUMBER := PKG_EMPLOYEE.generate_emp_number;
    :EMPLOYEE.ACTIVE_FLAG := 'Y';
    :EMPLOYEE.EMPLOYMENT_STATUS := 'ACTIVE';
    :EMPLOYEE.CREATED_BY := :GLOBAL.current_user;
    :EMPLOYEE.CREATED_DATE := SYSDATE;
END;
      </TriggerText>
    </Trigger>

    <Trigger Name="PRE-UPDATE" TriggerStyle="PL/SQL">
      <TriggerText>
BEGIN
    :EMPLOYEE.MODIFIED_BY := :GLOBAL.current_user;
    :EMPLOYEE.MODIFIED_DATE := SYSDATE;
END;
      </TriggerText>
    </Trigger>

    <Trigger Name="POST-QUERY" TriggerStyle="PL/SQL">
      <TriggerText>
BEGIN
    -- Populate display items
    BEGIN
        SELECT DEPT_NAME INTO :EMPLOYEE.DEPT_NAME_DISP
        FROM DEPARTMENTS WHERE DEPT_ID = :EMPLOYEE.DEPT_ID;
    EXCEPTION WHEN NO_DATA_FOUND THEN :EMPLOYEE.DEPT_NAME_DISP := NULL;
    END;

    BEGIN
        SELECT JOB_TITLE INTO :EMPLOYEE.JOB_TITLE_DISP
        FROM JOB_TITLES WHERE JOB_ID = :EMPLOYEE.JOB_ID;
    EXCEPTION WHEN NO_DATA_FOUND THEN :EMPLOYEE.JOB_TITLE_DISP := NULL;
    END;

    BEGIN
        SELECT FIRST_NAME || ' ' || LAST_NAME INTO :EMPLOYEE.MANAGER_NAME_DISP
        FROM EMPLOYEES WHERE EMP_ID = :EMPLOYEE.MANAGER_EMP_ID;
    EXCEPTION WHEN NO_DATA_FOUND THEN :EMPLOYEE.MANAGER_NAME_DISP := NULL;
    END;
END;
      </TriggerText>
    </Trigger>

    <Trigger Name="WHEN-VALIDATE-ITEM" TriggerStyle="PL/SQL" FireInEnterQueryMode="No">
      <TriggerText>
DECLARE
    v_item VARCHAR2(60) := :SYSTEM.TRIGGER_ITEM;
BEGIN
    IF v_item = 'EMPLOYEE.EMAIL' THEN
        IF :EMPLOYEE.EMAIL IS NOT NULL
           AND NOT PKG_VALIDATION.validate_email_format(:EMPLOYEE.EMAIL) THEN
            MESSAGE('Invalid email format');
            RAISE FORM_TRIGGER_FAILURE;
        END IF;

    ELSIF v_item = 'EMPLOYEE.HIRE_DATE' THEN
        IF :EMPLOYEE.HIRE_DATE > SYSDATE + 90 THEN
            MESSAGE('Hire date cannot be more than 90 days in the future');
            RAISE FORM_TRIGGER_FAILURE;
        END IF;

    ELSIF v_item = 'EMPLOYEE.DEPT_ID' THEN
        -- Auto-populate department name
        BEGIN
            SELECT DEPT_NAME INTO :EMPLOYEE.DEPT_NAME_DISP
            FROM DEPARTMENTS
            WHERE DEPT_ID = :EMPLOYEE.DEPT_ID AND ACTIVE_FLAG = 'Y';
        EXCEPTION
            WHEN NO_DATA_FOUND THEN
                MESSAGE('Invalid department');
                RAISE FORM_TRIGGER_FAILURE;
        END;

    ELSIF v_item = 'EMPLOYEE.JOB_ID' THEN
        BEGIN
            SELECT JOB_TITLE INTO :EMPLOYEE.JOB_TITLE_DISP
            FROM JOB_TITLES
            WHERE JOB_ID = :EMPLOYEE.JOB_ID AND ACTIVE_FLAG = 'Y';
        EXCEPTION
            WHEN NO_DATA_FOUND THEN
                MESSAGE('Invalid job title');
                RAISE FORM_TRIGGER_FAILURE;
        END;
    END IF;
END;
      </TriggerText>
    </Trigger>

