  <!-- ================================================================== -->
  <!-- LOVs (List of Values)                                               -->
  <!-- ================================================================== -->
  <LOV Name="LOV_DEPARTMENTS" Title="Select Department"
       AutoDisplay="No" AutoSkip="No"
       Width="400" Height="300">
    <RecordGroup Name="RG_DEPARTMENTS"
                 QueryText="SELECT DEPT_ID, DEPT_CODE, DEPT_NAME, COST_CENTER
                            FROM HRMS.DEPARTMENTS WHERE ACTIVE_FLAG = 'Y'
                            ORDER BY DEPT_NAME"/>
    <ColumnMapping LOVColumn="DEPT_ID" ReturnItem="EMPLOYEE.DEPT_ID"/>
    <ColumnMapping LOVColumn="DEPT_NAME" ReturnItem="EMPLOYEE.DEPT_NAME_DISP"/>
  </LOV>

  <LOV Name="LOV_JOB_TITLES" Title="Select Job Title"
       AutoDisplay="No" Width="450" Height="300">
    <RecordGroup Name="RG_JOB_TITLES"
                 QueryText="SELECT j.JOB_ID, j.JOB_CODE, j.JOB_TITLE, g.GRADE_NAME
                            FROM HRMS.JOB_TITLES j
                            JOIN HRMS.JOB_GRADES g ON j.GRADE_ID = g.GRADE_ID
                            WHERE j.ACTIVE_FLAG = 'Y'
                            ORDER BY j.JOB_TITLE"/>
    <ColumnMapping LOVColumn="JOB_ID" ReturnItem="EMPLOYEE.JOB_ID"/>
    <ColumnMapping LOVColumn="JOB_TITLE" ReturnItem="EMPLOYEE.JOB_TITLE_DISP"/>
  </LOV>

  <LOV Name="LOV_MANAGERS" Title="Select Manager"
       AutoDisplay="No" Width="400" Height="300">
    <RecordGroup Name="RG_MANAGERS"
                 QueryText="SELECT EMP_ID, EMP_NUMBER,
                                   FIRST_NAME || ' ' || LAST_NAME AS MANAGER_NAME
                            FROM HRMS.EMPLOYEES
                            WHERE EMPLOYMENT_STATUS = 'ACTIVE'
                            ORDER BY LAST_NAME"/>
    <ColumnMapping LOVColumn="EMP_ID" ReturnItem="EMPLOYEE.MANAGER_EMP_ID"/>
    <ColumnMapping LOVColumn="MANAGER_NAME" ReturnItem="EMPLOYEE.MANAGER_NAME_DISP"/>
  </LOV>

  <LOV Name="LOV_LOCATIONS" Title="Select Location"
       AutoDisplay="No" Width="400" Height="300">
    <RecordGroup Name="RG_LOCATIONS"
                 QueryText="SELECT LOCATION_CODE, LOCATION_NAME, CITY, STATE_PROVINCE
                            FROM HRMS.LOCATIONS WHERE ACTIVE_FLAG = 'Y'
                            ORDER BY LOCATION_NAME"/>
    <ColumnMapping LOVColumn="LOCATION_CODE" ReturnItem="EMPLOYEE.LOCATION_CODE"/>
  </LOV>

